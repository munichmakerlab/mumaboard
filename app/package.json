{
  "name": "mumaboard-app",
  "version": "1.0.0",
  "description": "Touch-first monitor wall dashboard built with NW.js",
  "main": "index.html",
  "window": {
    "title": "MumaBoard",
    "toolbar": false,
    "frame": false,
    "fullscreen": true,
    "position": "center",
    "resizable": true
  },
  "webkit": {
    "plugin": true
  },
  "chromium-args": "--autoplay-policy=no-user-gesture-required"
}
